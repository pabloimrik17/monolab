{
    "name": "@m0n0lab/wealth-tracker-core",
    "version": "0.1.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/pabloimrik17/monolab.git",
        "directory": "packages/wealth-tracker-core"
    },
    "author": "Pablo F.G.",
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist",
        "package.json",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "scripts": {
        "build": "pnpm run build:typecheck && pnpm run build:lib",
        "build:check-exports": "attw --pack . --ignore-rules=cjs-resolves-to-esm",
        "build:lib": "tsdown",
        "build:typecheck": "tsc --noEmit",
        "lint:eslint": "eslint --cache --max-warnings 40 .",
        "lint:eslint:config-check": "eslint-config-prettier src/index.ts",
        "lint:eslint:fix": "eslint --cache --max-warnings 40 --fix .",
        "lint:knip": "knip --max-issues 70",
        "lint:knip:fix": "knip --fix",
        "lint:prettier": "prettier . --check",
        "lint:prettier:fix": "prettier . --write",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage",
        "test:ui": "vitest --ui",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "0.18.2",
        "tsdown": "0.15.9",
        "typescript": "5.9.3",
        "vitest": "catalog:"
    },
    "packageManager": "pnpm@10.27.0",
    "engines": {
        "node": "^20.18.0 || >=22.0.0",
        "pnpm": "10.27.0"
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    }
}
