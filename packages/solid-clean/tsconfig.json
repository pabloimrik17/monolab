{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "preserve",
        "moduleResolution": "bundler",
        "outDir": "./dist",
        "rootDir": "./src",
        "declaration": true,
        "composite": true,
        "jsx": "preserve",
        "jsxImportSource": "solid-js"
    },
    "include": ["src/**/*"],
    "exclude": [
        "**/*.test.ts",
        "**/*.test.tsx",
        "**/*.spec.ts",
        "**/*.spec.tsx"
    ]
}
