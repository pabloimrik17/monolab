{
    "name": "@m0n0lab/investlab-data",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "pnpm run build:typecheck && pnpm run build:lib",
        "build:lib": "tsdown",
        "build:typecheck": "tsc --noEmit",
        "db:generate": "drizzle-kit generate",
        "db:migrate": "drizzle-kit migrate",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@m0n0lab/investlab-domain": "workspace:*",
        "drizzle-orm": "0.44.7",
        "inversify": "7.11.0",
        "neverthrow": "8.2.0",
        "pg": "8.16.3"
    },
    "devDependencies": {
        "drizzle-kit": "0.31.10",
        "tsdown": "0.15.12",
        "typescript": "5.9.3",
        "vitest": "catalog:"
    },
    "engines": {
        "node": "^20.18.0 || >=22.0.0",
        "pnpm": "10.27.0"
    },
    "packageManager": "pnpm@10.27.0"
}
