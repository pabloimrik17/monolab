{
    "name": "@m0n0lab/ts-types",
    "version": "1.0.6",
    "author": "Pablo F.G.",
    "repository": {
        "type": "git",
        "url": "https://github.com/pabloimrik17/monolab.git",
        "directory": "packages/ts-types"
    },
    "files": [
        "dist",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "type": "module",
    "sideEffects": false,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "publishConfig": {
        "access": "public",
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "scripts": {
        "build": "tsc -b",
        "lint:eslint": "eslint --cache --max-warnings 40 .",
        "lint:eslint:config-check": "eslint-config-prettier src/index.ts",
        "lint:eslint:fix": "eslint --cache --max-warnings 40 --fix .",
        "lint:knip": "knip --max-issues 40",
        "lint:knip:fix": "knip --fix",
        "lint:oxfmt": "oxfmt --check .",
        "lint:oxfmt:fix": "oxfmt .",
        "test:mutation": "stryker run",
        "test:mutation:report": "open reports/mutation/index.html",
        "test:types": "vitest --typecheck.enabled --run",
        "test:types:watch": "vitest --typecheck.enabled",
        "test:ui": "vitest --ui",
        "test:unit": "vitest run",
        "test:unit:coverage": "vitest run --coverage",
        "test:unit:watch": "vitest",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "typescript": "5.9.3",
        "vitest": "catalog:"
    },
    "engines": {
        "node": "^20.18.0 || >=22.0.0",
        "pnpm": "10.27.0"
    },
    "packageManager": "pnpm@10.27.0"
}
