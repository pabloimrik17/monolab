{
    "name": "@m0n0lab/investlab",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "pnpm run build:typecheck && pnpm run build:lib",
        "build:lib": "tsdown",
        "build:typecheck": "tsc --noEmit",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@m0n0lab/investlab-core": "workspace:*",
        "@m0n0lab/investlab-data": "workspace:*",
        "@m0n0lab/investlab-domain": "workspace:*",
        "@m0n0lab/wealth-tracker-core": "workspace:*",
        "drizzle-orm": "0.44.2",
        "inversify": "7.11.0",
        "ioredis": "5.6.1",
        "pg": "8.16.0"
    },
    "devDependencies": {
        "@types/pg": "8.15.4",
        "tsdown": "0.15.9",
        "typescript": "5.9.3",
        "vitest": "catalog:"
    },
    "engines": {
        "node": "v25.9.0",
        "pnpm": "10.27.0"
    },
    "packageManager": "pnpm@10.27.0"
}
