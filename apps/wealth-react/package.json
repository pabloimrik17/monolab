{
    "name": "@m0n0lab/wealth-react",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "react-router build",
        "dev": "react-router dev",
        "lint:eslint": "eslint --cache --max-warnings 60 .",
        "lint:knip": "knip --max-issues 100",
        "lint:prettier": "prettier . --check",
        "start": "react-router-serve ./build/server/index.js",
        "typecheck": "tsc --noEmit",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:unit:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@m0n0lab/wealth-tracker-core": "workspace:*",
        "react": "19.2.5",
        "react-dom": "19.2.5",
        "react-router": "7.13.2"
    },
    "devDependencies": {
        "@react-router/dev": "7.13.2",
        "@react-router/node": "7.13.2",
        "@react-router/serve": "7.13.2",
        "@types/react": "^19.0.14",
        "@types/react-dom": "^19.0.6",
        "@vitest/coverage-v8": "catalog:",
        "typescript": "5.9.3",
        "vite": "6.4.2",
        "vitest": "catalog:"
    },
    "engines": {
        "node": "24.12.0",
        "pnpm": "10.27.0"
    },
    "packageManager": "pnpm@10.27.0"
}
