{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":dependencyDashboard",
        ":semanticCommits",
        ":enableVulnerabilityAlertsWithLabel(security)",
        "helpers:pinGitHubActionDigestsToSemver"
    ],
    "timezone": "Europe/Madrid",
    "reviewers": ["pabloimrik17"],
    "labels": ["dependencies"],
    "baseBranchPatterns": ["develop"],
    "dependencyDashboardTitle": "📦 Dependency Dashboard",
    "prConcurrentLimit": 10,
    "prHourlyLimit": 2,
    "configMigration": true,
    "minimumReleaseAge": "14 days",
    "rangeStrategy": "pin",
    "packageRules": [
        {
            "matchUpdateTypes": ["patch"],
            "schedule": ["on the 1st day of the month"]
        },
        {
            "matchUpdateTypes": ["minor"],
            "schedule": ["on the 8th day of the month every 2 months"]
        },
        {
            "matchUpdateTypes": ["major"],
            "schedule": ["on the 15th day of the month every 3 months"]
        },
        {
            "description": "Seguir versionado de Expo con ~",
            "rangeStrategy": "tilde",
            "matchPackageNames": ["/^expo($|-)/", "/^@expo//"]
        },
        {
            "description": "Keep node engine ranges in libraries instead of pinning",
            "matchFileNames": ["packages/**"],
            "matchDepNames": ["node"],
            "rangeStrategy": "replace"
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "description": "Update pinned MCP server versions in opencode.json",
            "fileMatch": ["^opencode\\.json$"],
            "matchStrings": ["\"(?<depName>@?[^\"@]+)@(?<currentValue>[^\"]+)\""],
            "datasourceTemplate": "npm"
        },
        {
            "customType": "regex",
            "description": "Update pinned MCP server versions in .mcp.json",
            "fileMatch": ["^\\.mcp\\.json$"],
            "matchStrings": ["\"(?<depName>@?[^\"@]+)@(?<currentValue>[^\"]+)\""],
            "datasourceTemplate": "npm"
        },
        {
            "customType": "regex",
            "description": "Update pinned CLI tool versions in CI workflows (pnpm dlx/bunx/npx)",
            "fileMatch": ["^\\.github/workflows/.+\\.ya?ml$"],
            "matchStrings": [
                "(?:pnpm dlx|bunx|npx) (?<depName>(?:@[^/\\s]+/)?[^@\\s]+)@(?<currentValue>[^\\s]+)"
            ],
            "datasourceTemplate": "npm"
        }
    ]
}
